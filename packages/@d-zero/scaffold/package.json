{
	"name": "@d-zero/scaffold",
	"version": "5.0.0-alpha.45",
	"description": "Frontend scaffold files of D-ZERO Co., Ltd.",
	"repository": "https://github.com/d-zero-dev/frontend-env.git",
	"author": "D-ZERO Co., Ltd.",
	"license": "MIT",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "package.json",
	"scripts": {
		"build": "npx @d-zero/builder",
		"dev": "eleventy --serve --watch",
		"d": "yarn dev",
		"lint": "run-s lint:*",
		"lint:html": "markuplint \"./__assets/**/*.{pug,html}\"",
		"lint:pug": "pug-lint ./__assets/htdocs/**/*.pug -r console; pug-lint ./__assets/_libs/**/*.pug -r console;",
		"lint:css": "stylelint \"./__assets/**/*.scss\" --fix",
		"lint:js": "eslint \"./__assets/**/*.{js,mjs,cjs,jsx,ts,tsx}\" --fix",
		"lint:ts": "tsc --noEmit",
		"lint:format": "prettier --write \"{*,./__assets/**/*}.{js,jsx,ts,tsx,scss,pug,html,json,yaml,*rc}\"",
		"lint:spell": "cspell --no-progress --show-suggestions \"**\"",
		"lint:text": "textlint \"./__assets/**/*.{pug,html}\"",
		"test": "vitest run",
		"prepare": "husky",
		"up": "yarn upgrade-interactive --latest"
	},
	"browserslist": [
		"last 1 chrome version",
		"last 1 firefox version",
		"last 1 edge version",
		"last 1 and_chr version",
		"last 2 safari version",
		"last 2 ios_saf version"
	],
	"devDependencies": {
		"@d-zero/builder": "5.0.0-alpha.45",
		"@d-zero/linters": "5.0.0-alpha.63",
		"@d-zero/postcss-config": "5.0.0-alpha.45",
		"@d-zero/tsconfig": "0.4.1",
		"@types/node": "22.15.19",
		"cross-env": "7.0.3",
		"husky": "9.1.7",
		"npm-run-all2": "8.0.2",
		"sass": "1.89.0",
		"typescript": "5.8.3",
		"vitest": "3.1.3"
	},
	"dependencies": {
		"@d-zero/custom-components": "5.0.0-alpha.45",
		"destyle.css": "4.0.1",
		"dialog-toggle-events-polyfill": "1.1.4",
		"invokers-polyfill": "0.5.2",
		"tslib": "2.8.1"
	},
	"volta": {
		"node": "22.15.1",
		"yarn": "1.22.22"
	}
}

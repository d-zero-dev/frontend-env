{
	"name": "@d-zero/scaffold",
	"version": "5.0.0-beta.18",
	"description": "Frontend scaffold files of D-ZERO Co., Ltd.",
	"repository": "https://github.com/d-zero-dev/frontend-env.git",
	"author": "D-ZERO Co., Ltd.",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "package.json",
	"production": {
		"host": "https://example.com",
		"siteName": "__サイト名__"
	},
	"scripts": {
		"build": "yarn lint && npx kamado build",
		"build:only": "npx kamado build",
		"dev": "npx kamado dev",
		"d": "yarn dev",
		"lint": "run-s \"lint:*\"",
		"lint:html": "npx markuplint \"./__assets/**/*.{pug,html}\"",
		"lint:pug": "npx pug-lint ./__assets/htdocs/**/*.pug -r console; npx pug-lint ./__assets/_libs/**/*.pug -r console;",
		"lint:css": "npx stylelint \"./__assets/**/*.css\" --fix",
		"lint:js": "npx eslint \"./__assets/**/*.{js,mjs,cjs,jsx,ts,tsx}\" --fix",
		"lint:ts": "tsc --noEmit",
		"lint:format": "npx prettier --write \"{*,./__assets/**/*}{.{js,jsx,ts,tsx,css,pug,html,json,yaml},*rc}\"",
		"lint:spell": "npx cspell --no-progress --show-suggestions \"**\"",
		"lint:text": "npx textlint \"./__assets/**/*.{pug,html}\"",
		"test": "vitest run",
		"bge": "npx @burger-editor/local",
		"print": "npx @d-zero/print -f __info/print.txt --type note",
		"prepare": "husky",
		"update": "yarn upgrade-interactive"
	},
	"browserslist": [
		"last 1 chrome version",
		"last 1 firefox version",
		"last 1 edge version",
		"last 1 and_chr version",
		"last 2 safari version",
		"last 2 ios_saf version"
	],
	"devDependencies": {
		"@burger-editor/local": "4.0.0-alpha.42",
		"@d-zero/cspell-config": "5.0.0-alpha.76",
		"@d-zero/eslint-config": "5.0.0-alpha.75",
		"@d-zero/lint-staged-config": "5.0.0-alpha.75",
		"@d-zero/markuplint-config": "5.0.0-alpha.75",
		"@d-zero/postcss-config": "5.0.0-beta.18",
		"@d-zero/prettier-config": "5.0.0-alpha.75",
		"@d-zero/pug-lint-config": "5.0.0-alpha.75",
		"@d-zero/stylelint-config": "5.0.0-alpha.75",
		"@d-zero/textlint-config": "5.0.0-alpha.75",
		"@d-zero/tsconfig": "0.5.0",
		"@kamado-io/page-compiler": "0.1.0-alpha.6",
		"@kamado-io/pug-compiler": "0.1.0-alpha.6",
		"@kamado-io/script-compiler": "0.1.0-alpha.6",
		"@kamado-io/style-compiler": "0.1.0-alpha.6",
		"@prettier/plugin-pug": "3.4.2",
		"@types/node": "24.10.4",
		"cross-env": "10.1.0",
		"dotenv": "17.2.3",
		"husky": "9.1.7",
		"kamado": "0.1.0-alpha.6",
		"npm-run-all2": "8.0.4",
		"typescript": "5.9.3",
		"vitest": "4.0.16"
	},
	"dependencies": {
		"@burger-editor/css": "4.0.0-alpha.42",
		"@d-zero/custom-components": "5.0.0-beta.18",
		"dialog-toggle-events-polyfill": "1.1.4",
		"invokers-polyfill": "0.5.7",
		"kiso.css": "1.2.2",
		"tslib": "2.8.1"
	},
	"packageManager": "yarn@4.12.0",
	"volta": {
		"node": "24.12.0",
		"yarn": "4.12.0"
	}
}

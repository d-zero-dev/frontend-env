{
	"name": "@d-zero/scaffold",
	"version": "5.0.0-beta.4",
	"description": "Frontend scaffold files of D-ZERO Co., Ltd.",
	"repository": "https://github.com/d-zero-dev/frontend-env.git",
	"author": "D-ZERO Co., Ltd.",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "package.json",
	"scripts": {
		"build": "yarn lint && npx @d-zero/builder",
		"build:only": "npx @d-zero/builder",
		"dev": "npx eleventy --serve --watch",
		"d": "yarn dev",
		"lint": "run-s \"lint:*\"",
		"lint:html": "npx markuplint \"./__assets/**/*.{pug,html}\"",
		"lint:pug": "npx pug-lint ./__assets/htdocs/**/*.pug -r console; npx pug-lint ./__assets/_libs/**/*.pug -r console;",
		"lint:css": "npx stylelint \"./__assets/**/*.css\" --fix",
		"lint:js": "npx eslint \"./__assets/**/*.{js,mjs,cjs,jsx,ts,tsx}\" --fix",
		"lint:ts": "tsc --noEmit",
		"lint:format": "npx prettier --write \"{*,./__assets/**/*}.{js,jsx,ts,tsx,css,pug,html,json,yaml,*rc}\"",
		"lint:spell": "npx cspell --no-progress --show-suggestions \"**\"",
		"lint:text": "npx textlint \"./__assets/**/*.{pug,html}\"",
		"test": "vitest run",
		"bge": "npx @burger-editor/local",
		"print": "npx @d-zero/print -f __info/print.txt --type note",
		"prepare": "husky",
		"up": "yarn upgrade-interactive --latest"
	},
	"browserslist": [
		"last 1 chrome version",
		"last 1 firefox version",
		"last 1 edge version",
		"last 1 and_chr version",
		"last 2 safari version",
		"last 2 ios_saf version"
	],
	"devDependencies": {
		"@burger-editor/local": "4.0.0-alpha.14",
		"@d-zero/builder": "5.0.0-beta.4",
		"@d-zero/linters": "5.0.0-alpha.70",
		"@d-zero/postcss-config": "5.0.0-beta.4",
		"@d-zero/tsconfig": "0.5.0",
		"@types/node": "22.17.1",
		"cross-env": "10.0.0",
		"husky": "9.1.7",
		"npm-run-all2": "8.0.4",
		"typescript": "5.9.2",
		"vitest": "3.2.4"
	},
	"dependencies": {
		"@burger-editor/css": "4.0.0-alpha.14",
		"@d-zero/custom-components": "5.0.0-beta.4",
		"dialog-toggle-events-polyfill": "1.1.4",
		"invokers-polyfill": "0.5.6",
		"kiso.css": "1.2.2",
		"tslib": "2.8.1"
	},
	"packageManager": "yarn@4.9.2",
	"volta": {
		"node": "24.5.0",
		"yarn": "4.9.2"
	}
}

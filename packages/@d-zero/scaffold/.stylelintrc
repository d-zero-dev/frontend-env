{
	"extends": ["@d-zero/stylelint-config"],
	"rules": {
		"selector-type-no-unknown": [
			true,
			{
				"ignoreTypes": ["/^c-.+$/"]
			}
		]
	},
	"overrides": [
		{
			"files": ["c-*.scss"],
			"rules": {
				"@d-zero/component": {
					"allowMultipleSelectors": true
				}
			}
		},
		{
			"files": ["c-content-main.scss"],
			"rules": {
				"selector-class-pattern": null,
				"selector-nested-pattern": "^(?!\\.c-).*"
			}
		}
	]
}

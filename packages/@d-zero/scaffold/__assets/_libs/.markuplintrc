{
	"extends": ["../../markuplint.config.js"],
	"nodeRules": [
		{
			"selector": "link, script",
			"rules": {
				"invalid-attr": {
					"options": {
						"allowAttrs": {
							"⚠️": {
								"type": "Any"
							}
						}
					}
				}
			}
		},
		{
			"selector": "script[⚠️], script[src*=jquery]",
			"rules": {
				"required-attr": false
			}
		}
	]
}

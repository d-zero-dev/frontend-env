doctype html
html(lang=lang || "ja")
	head
		include /mixin/meta.pug
	body.l-home
		.l-home__base
			.l-home__header
				- const isHome = true;
				include /component/c-header.pug
			.l-home__nav-global
				include /component/c-nav-global.pug
			.l-home__main
				main !{ content }
			.l-home__nav-sitemap
				include /component/c-nav-sitemap.pug
			.l-home__footer
				include /component/c-footer.pug

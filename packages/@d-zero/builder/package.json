		"dayjs": "1.11.19",
		"esbuild": "0.27.0",
		"filesize": "11.0.13",
		"gzip-size": "7.0.0",
		"html-minifier-terser": "7.2.0",
		"iconv-lite": "0.7.0",
		"image-size": "2.0.2",
		"js-yaml": "4.1.1",
		"jsdom": "27.2.0",

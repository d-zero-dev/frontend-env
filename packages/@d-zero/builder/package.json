{
	"name": "@d-zero/builder",
	"version": "5.0.0-beta.0",
	"description": "Builder of D-ZERO Frontend",
	"repository": "https://github.com/d-zero-dev/frontend-env.git",
	"author": "D-ZERO Co., Ltd.",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"bin": {
		"dzbuild": "./bin/dzbuild.js"
	},
	"exports": {
		"./11ty": {
			"import": "./dist/eleventy.config.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"dev": "tsc --watch --project tsconfig.build.json"
	},
	"files": [
		"dist",
		"bin"
	],
	"dependencies": {
		"@11ty/eleventy": "3.1.2",
		"@d-zero/shared": "0.9.0",
		"@types/postcss-import": "14.0.3",
		"@types/postcss-load-config": "3.0.1",
		"character-entities": "2.0.2",
		"cli-color": "2.0.4",
		"cssnano": "7.0.7",
		"dayjs": "1.11.13",
		"esbuild": "0.25.5",
		"filesize": "10.1.6",
		"gzip-size": "7.0.0",
		"html-minifier-terser": "7.2.0",
		"iconv-lite": "0.6.3",
		"image-size": "2.0.2",
		"js-yaml": "4.1.0",
		"jsdom": "26.1.0",
		"minimatch": "10.0.3",
		"postcss": "8.5.6",
		"postcss-import": "16.1.1",
		"postcss-load-config": "6.0.1",
		"prettier": "3.5.3",
		"pug": "3.0.3"
	},
	"devDependencies": {
		"@types/cli-color": "2.0.6",
		"@types/html-minifier-terser": "7.0.2",
		"@types/js-yaml": "4.0.9",
		"@types/jsdom": "21.1.7",
		"@types/pug": "2.0.10",
		"execa": "9.6.0",
		"ignore": "7.0.5",
		"prettier": "3.5.3",
		"strip-ansi": "7.1.0"
	}
}
